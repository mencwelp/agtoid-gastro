<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <title>Agtoid Gastro</title>

  <meta name="viewport"
        content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#4f46e5">

  <link rel="stylesheet" href="framework7.bundle.min.css">
  <link rel="stylesheet" href="style.css">
  <link rel="manifest" href="manifest.json">
</head>

<body>
<div id="app">

  <!-- HEADER -->
<div class="app-header">
  <div class="app-title-box">
    <h1 class="app-title">
      <span class="app-icon">🛍️</span> Agtoid Gastro
    </h1>
    <span class="app-subtitle">Gestão de encomendas por categoria</span>
  </div>

  <div id="drive-status" class="status-indicator online">
    <span class="dot"></span>
    <span  class="label">Online</span> 
  </div>
</div>

  <!-- TOP PANEL -->
  <div class="top-panel">
    <input id="searchInput" class="search-input" placeholder="Pesquisar produto...">

    <select id="filterCategorias" class="filter-select">
      <option value="all">Todas as categorias</option>
      <option value="Vegetais">Vegetais</option>
      <option value="Frutas">Frutas</option>
      <option value="Carne">Carne</option>
      <option value="Peixe">Peixe</option>
      <option value="Laticínios">Laticínios</option>
      <option value="Bebidas">Bebidas</option>
      <option value="Padaria">Padaria</option>
      <option value="Congelados">Congelados</option>
    </select>

    <button class="filter-btn" id="filterUrgente">🚨</button>

    <button class="action-btn green" id="btnGeneruj">📄</button>
    <button class="action-btn red" id="btnClear">🧹</button>
    <button id="btnDrive" class="filter-btn">🔗</button>

  </div>

  <!-- MAIN VIEW -->
  <div class="view view-main view-init safe-areas" data-url="/">
    <div class="page">

      <!-- BOTTOM TOOLBAR -->
      <div class="toolbar tabbar toolbar-bottom">
        <div class="toolbar-inner">
          <a href="#tab-encomenda" class="tab-link tab-link-active">🧺 Encomenda</a>
          <a href="#tab-catalogo" class="tab-link">📦 Catálogo</a>
          <a href="#tab-categorias" class="tab-link">🗂 Categorias</a>
          <a href="#tab-relatorio" class="tab-link">📄 Relatório</a>
        </div>
      </div>

      <!-- TABS -->
      <div class="tabs">

        <!-- TAB 1: ENCOMENDA -->
        <div id="tab-encomenda" class="page-content tab tab-active">
          <div id="listaPedido"></div>

          <!-- STATUS BAR -->
          <div class="status-bar">
            <span id="statusTotal">Total: 0 itens</span>
            <span id="statusUrgente">Urgente: 0</span>
          </div>
        </div>

        <!-- TAB 2: CATÁLOGO -->
        <div id="tab-catalogo" class="page-content tab">
          <div class="block">
            <button id="btnAddProduto" class="button button-fill color-blue">
              ➕ Adicionar Produto
            </button>
            <button id="btnResetCatalogo" class="button button-fill color-red">
              🔄 Reset Catálogo
            </button>
          </div>

          <div id="listaProdutos"></div>
        </div>

        <!-- TAB 3: CATEGORIAS -->
        <div id="tab-categorias" class="page-content tab">
          <div class="block">
            <button id="btnAddCategoria" class="button button-fill color-blue">
              ➕ Adicionar Categoria
            </button>
          </div>

          <div id="listaCategorias"></div>
        </div>

        <!-- TAB 4: RELATÓRIO -->
        <div id="tab-relatorio" class="page-content tab">

          <div class="block">
            <button id="btnExportWhatsApp" class="button button-fill color-green">
              📲 Enviar via WhatsApp
            </button>
            <button id="btnExportEmail" class="button button-fill color-blue">
              ✉️ Enviar por Email
            </button>
            <button id="btnPrint" class="button button-fill color-gray">
              🖨️ Imprimir
            </button>
            <button id="btnCopiarRelatorio" class="button button-fill color-black">
              📋 Copiar
            </button>
          </div>

          <div class="block">
            <h3>Relatório Tabelar</h3>
            <table id="tabelaRelatorio" class="relatorio-table"></table>
          </div>

          <div class="block">
            <h3>Texto do Relatório</h3>
            <textarea id="relatorioTexto" class="relatorio-texto"></textarea>
          </div>

        </div>

      </div>
    </div>
  </div>
</div>

<!-- MODAL: ADICIONAR / EDITAR PRODUTO -->
<div class="popup" id="popupProduto">
  <div class="view">
    <div class="page">
      <div class="navbar">
        <div class="navbar-inner">
          <div class="title" id="produtoTitulo">Produto</div>
          <div class="right">
            <a class="link popup-close">Fechar</a>
          </div>
        </div>
      </div>

      <div class="page-content">
        <div class="list no-hairlines-md">
          <ul>
            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Nome</div>
                  <div class="item-input-wrap">
                    <input type="text" id="produtoNome">
                  </div>
                </div>
              </div>
            </li>

            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Categoria</div>
                  <div class="item-input-wrap">
                    <select id="produtoCategoria"></select>
                  </div>
                </div>
              </div>
            </li>

            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Unidade</div>
                  <div class="item-input-wrap">
                    <select id="produtoUnidade">
                      <option value="kg">kg</option>
                      <option value="unid">unid</option>
                      <option value="pacote">pacote</option>
                      <option value="litro">litro</option>
                      <option value="cx">cx</option>
                    </select>
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <div class="block">
          <button id="btnSalvarProduto" class="button button-fill color-green">Salvar</button>
          <button id="btnExcluirProduto" class="button button-fill color-red">Excluir</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL: ADICIONAR / EDITAR CATEGORIA -->
<div class="popup" id="popupCategoria">
  <div class="view">
    <div class="page">
      <div class="navbar">
        <div class="navbar-inner">
          <div class="title" id="categoriaTitulo">Categoria</div>
          <div class="right">
            <a class="link popup-close">Fechar</a>
          </div>
        </div>
      </div>

      <div class="page-content">
        <div class="list no-hairlines-md">
          <ul>
            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Nome</div>
                  <div class="item-input-wrap">
                    <input type="text" id="categoriaNome">
                  </div>
                </div>
              </div>
            </li>

            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Ícone</div>
                  <div class="item-input-wrap">
                    <input type="text" id="categoriaIcone" placeholder="🥬 🍊 🥩 🐟">
                  </div>
                </div>
              </div>
            </li>

            <li>
              <div class="item-content item-input">
                <div class="item-inner">
                  <div class="item-title item-label">Cor</div>
                  <div class="item-input-wrap">
                    <input type="color" id="categoriaCor">
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <div class="block">
          <button id="btnSalvarCategoria" class="button button-fill color-green">Salvar</button>
          <button id="btnExcluirCategoria" class="button button-fill color-red">Excluir</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://accounts.google.com/gsi/client"></script>
<script src="https://apis.google.com/js/api.js"></script>

<script src="framework7.bundle.min.js"></script>
<script src="app.js"></script>

<script type="text/javascript" src="https://apis.google.com/js/api.js"></script>
<script type="text/javascript" src="https://accounts.google.com/gsi/client"></script>   
<script src="https://apis.google.com/js/api.js" onload="onApiLoad()"></script>
<script src="https://accounts.google.com/gsi/client"></script>

<script>
if ("serviceWorker" in navigator) {
  navigator.serviceWorker.register("/sw.js");
}
</script>

</body>
</html>
